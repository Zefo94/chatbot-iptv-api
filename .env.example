# ==============================================================================
# IPTV XUI.ONE MANAGEMENT SERVICE ENVIRONMENT CONFIGURATION (TEMPLATE)
# ==============================================================================

APP_ENV=local
APP_DEBUG=true
APP_URL=http://your-domain.com

# Chatbot Client security key
CHATBOT_API_KEY=your_super_secure_chatbot_key

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=iptv_manager
DB_USER=root
DB_PASS=password

# XUI.ONE Panel APIs
XUI_API_URL=http://xui-domain.com:8000/api.php
XUI_USERNAME=admin
XUI_PASSWORD=password
XUI_DEFAULT_PACKAGE_ID=1
XUI_DEFAULT_MAX_CONNECTIONS=1

# Payment Gateways
WOMPI_PUBLIC_KEY=pub_test_wompi_key
WOMPI_PRIVATE_KEY=prv_test_wompi_key
WOMPI_WEBHOOK_SECRET=wompi_webhook_signature

MERCADOPAGO_ACCESS_TOKEN=mp_token_here
MERCADOPAGO_WEBHOOK_SECRET=mp_secret_here

PAYPAL_CLIENT_ID=paypal_client_id_here
PAYPAL_CLIENT_SECRET=paypal_client_secret_here
PAYPAL_MODE=sandbox

BINANCE_API_KEY=binance_key_here
BINANCE_SECRET_KEY=binance_secret_here
